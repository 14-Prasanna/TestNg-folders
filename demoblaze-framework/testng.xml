<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  ╔══════════════════════════════════════════════════════════════╗
  ║       DemoBlaze Automation Framework - TestNG Suite          ║
  ║       Parallel Execution | Login + Dashboard Features        ║
  ╚══════════════════════════════════════════════════════════════╝
-->

<suite name="DemoBlaze_Automation_Suite"
       parallel="tests"
       thread-count="2"
       verbose="2">

  <listeners>
    <listener class-name="com.demoblaze.utils.TestListener"/>
  </listeners>

  <!-- ===== LOGIN FEATURE TESTS ===== -->
  <test name="Login_Valid_Tests" preserve-order="true">
    <parameter name="browser" value="chrome"/>
    <parameter name="baseUrl"  value="https://demoblaze.com/"/>
    <parameter name="sheet"    value="ValidCredentials"/>
    <classes>
      <class name="com.demoblaze.runner.LoginRunner"/>
    </classes>
  </test>

  <!-- ===== INVALID LOGIN TESTS (separate thread) ===== -->
  <test name="Login_Invalid_Tests" preserve-order="true">
    <parameter name="browser" value="chrome"/>
    <parameter name="baseUrl"  value="https://demoblaze.com/"/>
    <parameter name="sheet"    value="InvalidCredentials"/>
    <classes>
      <class name="com.demoblaze.runner.LoginInvalidRunner"/>
    </classes>
  </test>

  <!-- ===== DASHBOARD FEATURE TESTS ===== -->
  <test name="Dashboard_Tests" preserve-order="true">
    <parameter name="browser" value="chrome"/>
    <parameter name="baseUrl"  value="https://demoblaze.com/"/>
    <parameter name="sheet"    value="ValidCredentials"/>
    <classes>
      <class name="com.demoblaze.runner.DashboardRunner"/>
    </classes>
  </test>

</suite>
